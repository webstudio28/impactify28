# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either anon or publishable key (same pattern as Guestcap)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role — required for /api/cron/process-sms (Guestcap-style createAdminClient)
SUPABASE_SERVICE_ROLE_KEY=

# SMS: budgetsms | connectix | twilio | vonage
SMS_PROVIDER=connectix

# Optional for providers that accept a configurable sender / callback (Guestcap parity)
SMS_SENDER_ID=
SMS_CALLBACK_URL=

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Vonage — https://dashboard.nexmo.com
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# BudgetSMS.net — https://www.budgetsms.net/sms-http-api/
BUDGETSMS_USERNAME=
BUDGETSMS_USERID=
BUDGETSMS_HANDLE=
BUDGETSMS_USE_TEST=1

# Connectix.bg — https://api.connectix.bg (template-based SMS)
CONNECTIX_TOKEN=
CONNECTIX_TEMPLATE_ID=
# CONNECTIX_TEMPLATE_MESSAGE_PARAM=test_text
# CONNECTIX_SANDBOX=1
# CONNECTIX_BASE=

# Cron / scheduler
CRON_SECRET=generate-a-long-random-string

# Upstash QStash — background campaign sending (https://console.upstash.com/qstash)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Public URL QStash calls back (production app URL). Falls back to NEXT_PUBLIC_SITE_URL / VERCEL_URL.
# QSTASH_CALLBACK_URL=https://app.impactify28.com
# Optional per-worker batch sizes for one QStash invocation
# EMAIL_WORKER_BATCH_LIMIT=400
# SMS_WORKER_BATCH_LIMIT=80

# Short links (SMS) — same host on server + browser (wizard “already shortened” check)
SHORT_DOMAIN=rvo5.com
NEXT_PUBLIC_SHORT_DOMAIN=rvo5.com

# Email builder — prefill all fields with sample Rock Bunker product (dev/testing only)
EMAIL_PREFILL=false

# Resend — https://resend.com/api-keys (required to send email campaigns)
RESEND_API_KEY=
# Platform sending address — all campaigns are sent FROM this address (must be verified in Resend).
# Users set their own display name; this is the technical sender.
# Must be on a domain you own and verify in Resend — NOT @gmail.com / @yahoo.com etc.
RESEND_FROM_EMAIL=hello@impactify28.com

# Email throughput controls (Resend batch API)
# Provider default is often 5 req/sec; keep effective at ~80% by default.
EMAIL_PROVIDER_MAX_REQ_PER_SEC=5
EMAIL_EFFECTIVE_RPS=4
EMAIL_BATCH_SIZE=100

# Email tracking and browser-view links
TRACKING_HMAC_SECRET=generate-a-long-random-string
# Optional explicit base URL for tracking links (defaults to NEXT_PUBLIC_SITE_URL or VERCEL_URL)
# TRACKING_BASE_URL=https://app.impactify28.com

# Optional: cap how many recipients are queued per email launch (for safe testing). Omit for no cap.
# EMAIL_LAUNCH_MAX_RECIPIENTS=100
